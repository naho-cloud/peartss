<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Remove index.php from URL
    RewriteCond %{THE_REQUEST} ^GET.*index\.php [NC]
    RewriteRule (.*?)index\.php/*(.*) /$1$2 [R=301,NE,L]
    
    # Handle errors
    ErrorDocument 404 /pearts/404.php
    ErrorDocument 403 /pearts/403.php
    
    # Prevent directory listing
    Options -Indexes
    
    # Protect sensitive files
    <FilesMatch "\.(ini|log|sql|txt)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>